generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  images    Image[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Image {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  motionEventId String?
  motionEvent   MotionEvent? @relation(fields: [motionEventId], references: [id], onDelete: SetNull)
  data          String
  mimeType      String?
  filename      String?
  createdAt     DateTime     @default(now())
}

model MotionEvent {
  id        String   @id @default(uuid())
  payload   String
  createdAt DateTime @default(now())
  images    Image[]
}
